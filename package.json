{
  "name": "mcp-policy",
  "version": "0.1.0",
  "description": "Enforce MCP server allowlists and blocklists against developer configs. CLI + GitHub Action.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "policy",
    "allowlist",
    "blocklist",
    "cli",
    "github-action"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattschaller/mcp-policy"
  },
  "author": "Matthew Schaller <matt@mattschaller.com>",
  "type": "module",
  "bin": {
    "mcp-policy": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
